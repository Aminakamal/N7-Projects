enum Operation {Addition, Multiplication};

int calculer (Operation op, int x, int y) {
  int res = 0;
  if (op=Addition) {
    res = (x+y);
  } else {
    if (op=Multiplication) {
      res = (x*y);
    } else {
      res = 0;
    }
  }
  return res;
}

main {
  int a = 10;
  int b = 5;
  int r1 = calculer(Addition, a, b);
  print r1;
  int r2 = calculer(Multiplication, a, b);
  print r2;
}
